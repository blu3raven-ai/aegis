# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Aegis — Vulnerability Management Portal                                  │
# │                                                                           │
# │  Copy this file to .env, fill in all required values, then run:           │
# │    docker compose up -d                                                   │
# │                                                                           │
# │  Generate secrets with:                                                   │
# │    openssl rand -base64 32                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── App ────────────────────────────────────────────────────────────────────

SESSION_SECRET=<replace: openssl rand -base64 32>
APP_SECRET=<replace: openssl rand -base64 32>
APP_PORT=127.0.0.1:3000

# ALLOWED_HOSTS — optional. Loopback and the internal service name are always
# trusted, so local and compose deployments need nothing here. Set this only
# when serving the portal on a public hostname, as a comma-separated list
# (wildcards allowed):
# ALLOWED_HOSTS=scan.example.com

# ── Admin Account ─────────────────────────────────────────────────────────

ADMIN_PASSWORD=<replace: your-admin-password>
ADMIN_USERNAME=<replace: your-admin-username>
ADMIN_EMAIL=<replace: your-admin-email>

# ── Database ───────────────────────────────────────────────────────────────

POSTGRES_DB=<replace: your-db-name>
POSTGRES_USER=<replace: your-db-user>
POSTGRES_PASSWORD=<replace: your-db-password>
POSTGRES_PORT=127.0.0.1:5432

# ── Object Storage (MinIO) ────────────────────────────────────────────────
# MinIO refuses to start unless the user is >= 3 chars and the password is
# >= 8 chars; a shorter value crash-loops MinIO and blocks the whole stack.

MINIO_ROOT_USER=<replace: >= 3 chars>
MINIO_ROOT_PASSWORD=<replace: openssl rand -base64 24 — must be >= 8 chars>
MINIO_PORT=127.0.0.1:9000
MINIO_CONSOLE_PORT=127.0.0.1:9001

# ── Runner ─────────────────────────────────────────────────────────────────

RUNNER_NAME=local-runner
RUNNER_REGISTRATION_TOKEN=<replace: openssl rand -base64 32>

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Required for transactional email, including the email-change confirmation
# link. Without SMTP configured, self-service email changes are refused.
# PUBLIC_APP_URL is the base URL used to build links in those emails — set it to
# however users reach the portal (e.g. https://scan.example.com).
# PUBLIC_APP_URL=http://localhost:3000
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=<replace: smtp-user>
# SMTP_PASSWORD=<replace: smtp-password>
# SMTP_FROM=aegis@example.com
