# ┌─────────────────────────────────────────────────────────────────────────────┐
# │  Aegis — Vulnerability Management Portal                                  │
# │                                                                           │
# │  Copy this file to .env and run: docker compose up -d                     │
# │  These defaults work for local development out of the box.                │
# │                                                                           │
# │  For production, replace all secrets below with strong random values:     │
# │    openssl rand -base64 32                                                │
# └─────────────────────────────────────────────────────────────────────────────┘

# ── App ────────────────────────────────────────────────────────────────────

JWT_SHARED_SECRET=local-dev-jwt-secret-replace-in-production
SESSION_SECRET=local-dev-session-secret-replace-in-production
# APP_PORT=3000
# BACKEND_PORT=127.0.0.1:8000

# ── Admin Account ─────────────────────────────────────────────────────────

ADMIN_PASSWORD=admin
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@example.com

# ── Database ───────────────────────────────────────────────────────────────

POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=postgres
# POSTGRES_PORT=127.0.0.1:5432

# ── Object Storage (MinIO) ────────────────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001

# ── Runner ─────────────────────────────────────────────────────────────────

RUNNER_NAME=local-runner
RUNNER_REGISTRATION_TOKEN=local-dev-runner-token
RUNNER_S3_SECRET_KEY=local-dev-s3-secret
