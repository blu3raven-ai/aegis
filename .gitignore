# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.worktrees/
/.claude/
/.agents/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.venv/

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
data/
settings.*.json

# python runtime/build artifacts
__pycache__/
backend/.pytest_cache/
backend/**/*.egg-info/
runner/**/*.egg-info/

# Joern CPG storage written by joern --script when run with the repo as CWD.
# Each invocation spawns cpg.bin/, cpg.bin1/, cpg.bin2/ … directories.
/workspace/
*.pyc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# e2e test artifacts
e2e/.auth/
e2e/test-results/
e2e/test-results-smoke/
e2e/playwright-report/
e2e/playwright-report-smoke/
.env.test

# Internal architecture/process docs MUST NOT be committed.
# These live under .claude/ instead (gitignored).
backend/docs/
docs/internal/

# evaluation tools
.deepeval/
