{
  "name": "aegis-vscode",
  "displayName": "Aegis Security Scanner",
  "description": "Inline SAST, SCA, secret, and container findings from a self-hosted Aegis backend, surfaced in the editor and Problems panel.",
  "version": "0.2.0",
  "publisher": "aegis",
  "license": "MIT",
  "icon": "media/icon.png",
  "homepage": "https://github.com/blu3raven-ai/aegis#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/blu3raven-ai/aegis.git",
    "directory": "vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/blu3raven-ai/aegis/issues"
  },
  "qna": "https://github.com/blu3raven-ai/aegis/issues",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters",
    "Testing",
    "Other"
  ],
  "keywords": [
    "security",
    "sast",
    "sca",
    "secrets",
    "vulnerability",
    "scanner",
    "diagnostics",
    "cve",
    "supply chain",
    "self-hosted"
  ],
  "galleryBanner": {
    "color": "#0B0D0E",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aegis.scan",
        "title": "Aegis: Scan Current Repo",
        "icon": "$(play)"
      },
      {
        "command": "aegis.refresh",
        "title": "Aegis: Refresh Findings",
        "icon": "$(refresh)"
      },
      {
        "command": "aegis.decide",
        "title": "Aegis: Check Decision"
      },
      {
        "command": "aegis.showChain",
        "title": "Aegis: Show Attack Chain"
      },
      {
        "command": "aegis.snoozeFinding",
        "title": "Aegis: Snooze Finding for 7 Days"
      },
      {
        "command": "aegis.markFixed",
        "title": "Aegis: Mark Finding as Fixed"
      },
      {
        "command": "aegis.showFindingDetails",
        "title": "Aegis: Show Finding Details"
      },
      {
        "command": "aegis.scanFolder",
        "title": "Aegis: Scan This Folder",
        "icon": "$(shield)"
      },
      {
        "command": "aegis.scanFile",
        "title": "Aegis: Scan This File"
      },
      {
        "command": "aegis.rescanWithLatestRules",
        "title": "Aegis: Rescan with Latest Rules"
      },
      {
        "command": "aegis.startLiveFindings",
        "title": "Aegis: Start Live Findings"
      },
      {
        "command": "aegis.stopLiveFindings",
        "title": "Aegis: Stop Live Findings"
      },
      {
        "command": "aegis.clearLiveFindings",
        "title": "Aegis: Clear Live Findings"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "aegis.scan",
          "group": "navigation"
        },
        {
          "command": "aegis.scanFolder",
          "when": "explorerResourceIsFolder",
          "group": "aegis@1"
        },
        {
          "command": "aegis.scanFile",
          "when": "!explorerResourceIsFolder",
          "group": "aegis@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "aegis.scanFile",
          "group": "aegis@1"
        }
      ],
      "view/title": [
        {
          "command": "aegis.scan",
          "when": "view == aegis.findings",
          "group": "navigation@1"
        },
        {
          "command": "aegis.refresh",
          "when": "view == aegis.findings",
          "group": "navigation@2"
        },
        {
          "command": "aegis.rescanWithLatestRules",
          "when": "view == aegis.findings",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Aegis",
      "properties": {
        "aegis.cliPath": {
          "type": "string",
          "default": "aegis",
          "description": "Path to the aegis CLI binary (must be in PATH or provide absolute path)."
        },
        "aegis.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Aegis backend URL (e.g., https://aegis.example.org)."
        },
        "aegis.apiToken": {
          "type": "string",
          "default": "",
          "description": "Aegis API token for authenticating against the backend."
        },
        "aegis.org": {
          "type": "string",
          "default": "",
          "description": "Default organisation to scan (overrides AEGIS_DEFAULT_ORG env var)."
        },
        "aegis.scanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically refresh findings when a file is saved."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aegis-sidebar",
          "title": "Aegis",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "aegis-sidebar": [
        {
          "id": "aegis.findings",
          "name": "Findings"
        },
        {
          "id": "aegis.liveFindings",
          "name": "Live Findings"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && mocha 'out/tests/**/*.test.js'"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "mocha": "^10.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
